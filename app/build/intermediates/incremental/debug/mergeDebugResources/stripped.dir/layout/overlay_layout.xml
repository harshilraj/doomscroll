<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/overlayContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="80dp"
        android:paddingBottom="80dp">

        <!-- Main question — large, bold, centered -->
        <TextView
            android:id="@+id/tvOverlayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_title"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:fontFamily="@font/inter"
            android:textStyle="bold"
            android:textAlignment="center"
            android:letterSpacing="0.02"
            android:lineSpacingExtra="4dp" />

        <!-- Subtitle — softer color, smaller -->
        <TextView
            android:id="@+id/tvOverlaySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.02" />

        <!-- Detected app badge -->
        <TextView
            android:id="@+id/tvDetectedApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            android:textAlignment="center"
            android:layout_marginTop="40dp"
            android:letterSpacing="0.2"
            android:visibility="gone" />

        <!-- Buttons — staggered visual weight -->
        <LinearLayout
            android:id="@+id/buttonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:alpha="0"
            android:translationY="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDoSomethingBetter"
                style="@style/AccentButton"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="@string/do_something_better"
                android:enabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExitApp"
                style="@style/MutedButton"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/exit_app"
                android:enabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueAnyway"
                style="@style/TertiaryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/continue_anyway"
                android:enabled="false" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
